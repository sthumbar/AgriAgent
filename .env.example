# Agri AI Multi-Agent Assistant — Environment Variables
# Copy this file to .env and fill in your values

# ── Gemini / Google AI ──────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Paths ───────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./rag/vector_store
RAG_DOCUMENTS_DIR=./rag/documents
REPORTS_DIR=./reports
IMAGES_DIR=./images

# ── RAG settings ────────────────────────────────────────────────────────────
RAG_COLLECTION_NAME=agri_knowledge
RAG_TOP_K=3
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ── Image processing ────────────────────────────────────────────────────────
MAX_IMAGE_WIDTH=1024
MAX_IMAGE_HEIGHT=1024
ALLOWED_EXTENSIONS=jpg,jpeg,png,bmp,webp

# ── HITL Agronomist Review ───────────────────────────────────────────────────
LOW_CONFIDENCE_THRESHOLD=60
REVIEW_DB_PATH=rag/review_queue.db
